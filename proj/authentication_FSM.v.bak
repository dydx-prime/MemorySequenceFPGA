// authentication_FSM
// ID check and password check (crazy)
module authentication_FSM(
    input clk,
    input reset,
    input [3:0] id_input,
    input pswd_btn_press,
    input logged_out,

    output auth_passed, // password match
    output reg [3:0] display_data 
);

    wire [3:0] display_data_ID, display_data_password;
    wire [2:0] internal_user_ID;
    wire id_passed;

    ID_check id(.clk(clk),
                .reset(reset),
                .id_input(id_input),
                .pswd_btn_press(pswd_btn_press),
                .logged_out(logged_out),

                .auth_passed(id_passed),
                .display_data(display_data_ID),
                .internalID(internal_user_ID)
    );

    password_check pswd_check(.clk(clk),
                              .reset(reset),
                              .pswd_btn_press(pswd_btn_press),
                              .internalID(internal_user_ID),
                              .password_input(id_input),
                              .ID_check_passed(id_passed),
                              
                              .logged_in(auth_passed),
                              .display_data(display_data_password)
    );

    always@(*) begin
        if(!id_passed)
            display_data = display_data_ID;
        else
            display_data = display_data_password;
    end
    

endmodule